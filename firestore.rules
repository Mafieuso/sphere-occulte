rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isHautGrade() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/membres/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/membres/$(request.auth.uid)).data.role
          in ['haut_grade', 'admin'];
    }

    function memberGrade() {
      return get(/databases/$(database)/documents/membres/$(request.auth.uid)).data.grade;
    }

    function isCollecteurOrHigher() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/membres/$(request.auth.uid)) &&
        memberGrade() in [
          "Collecteur d'Ombre",
          "Marchand des Âmes",
          "Monarque des Ombres"
        ];
    }

    // ── Membres ────────────────────────────────────────────────
    match /membres/{userId} {
      allow read: if true;
      allow create: if isAuthenticated() && request.auth.uid == userId;
      allow update: if isAuthenticated() &&
        (request.auth.uid == userId || isHautGrade());
      allow delete: if isHautGrade();
    }

    // ── Incantations ───────────────────────────────────────────
    match /incantations/{incantationId} {
      allow read: if true;
      allow write: if isHautGrade();
    }

    // ── Soumissions ────────────────────────────────────────────
    match /soumissions/{soumissionId} {
      allow read: if isAuthenticated() &&
        (request.auth.uid == resource.data.membreId || isHautGrade());
      allow create: if isAuthenticated() &&
        request.auth.uid == request.resource.data.membreId;
      allow update: if isHautGrade();
      allow delete: if isHautGrade();
    }

    // ── Écoles ─────────────────────────────────────────────────
    match /ecoles/{ecoleId} {
      allow read: if isAuthenticated();
      allow create: if isCollecteurOrHigher() &&
        request.resource.data.fondateurId == request.auth.uid;
      allow update: if isAuthenticated() &&
        (resource.data.fondateurId == request.auth.uid || isHautGrade());
      allow delete: if isAuthenticated() &&
        (resource.data.fondateurId == request.auth.uid || isHautGrade());
    }

    // ── Savoirs Uniques ────────────────────────────────────────
    match /savoirsUniques/{savoirId} {
      allow read: if isAuthenticated();
      allow write: if isHautGrade();
    }

    // ── Logs ───────────────────────────────────────────────────
    match /logs/{logId} {
      allow read:   if isHautGrade();
      allow create: if isHautGrade();
      allow update, delete: if false;
    }
  }
}
